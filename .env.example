# Banco de dados — PostgreSQL (dev: Docker local ou Neon)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/morada_nas_nuvens?schema=public"

# Auth.js — usuária única (Mariana). Gere o hash com: npm run gerar-hash "sua-senha"
AUTH_SECRET="troque-por-um-segredo-aleatorio-longo"
AUTH_EMAIL="mariana@moradanasnuvens.com.br"
# Hash bcrypt da senha (NUNCA a senha em texto puro).
# Escape os "$" como "\$" — o Next expande variáveis no .env. O script gerar-hash já faz isso.
AUTH_PASSWORD_HASH=""

# Anthropic — SOMENTE no servidor, nunca exposta ao navegador
ANTHROPIC_API_KEY=""
